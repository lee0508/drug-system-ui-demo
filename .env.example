# =====================================================
# 마약류중독자관리시스템 — 환경 변수
# .env.example 파일을 복사하여 .env 로 만드세요
# cp .env.example .env
# =====================================================

# ─── PostgreSQL 데이터베이스 ───────────────────────────
# 형식: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/drug_system?schema=public"

# 로컬 Docker 예시:
# DATABASE_URL="postgresql://postgres:1234@localhost:5432/drug_system?schema=public"

# GCP Cloud SQL 예시:
# DATABASE_URL="postgresql://app_user:password@/drug_system?host=/cloudsql/project:region:instance"

# ─── Next.js ─────────────────────────────────────────
NEXTAUTH_SECRET="your-secret-key-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ─── 앱 설정 ─────────────────────────────────────────
NODE_ENV="development"
